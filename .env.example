# Copy to .env and fill in real values. Do NOT commit .env.

# MongoDB connection string (e.g. a free MongoDB Atlas cluster).
# For Vercel, the Atlas cluster must allow access from 0.0.0.0/0
# (Vercel's serverless IPs are dynamic).
MONGODB_URI=

# NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Canonical app URL used by NextAuth for callbacks/redirects.
# Local:      http://localhost:3000
# Production: your deployed URL, e.g. https://mystrymsg.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Resend API key for verification emails
RESEND_API_KEY=

# From-address for verification emails. Defaults to Resend's sandbox
# sender (onboarding@resend.dev), which only delivers to the Resend
# account owner's address. To email anyone, verify a domain at
# resend.com/domains and set this to an address on that domain.
EMAIL_FROM="True Feedback <onboarding@resend.dev>"

# Google Gemini API key (free tier, no credit card required).
# Optional — message suggestions fall back to canned prompts without it.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
